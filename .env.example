# ARID per-researcher settings -- copy to `.env` and give yourself a unique name.
#
#   cp .env.example .env      # then edit the values below
#
# Docker Compose reads `.env` automatically. This lets several researchers each
# run their own ARID stack on the *same shared host* at the same time, instead
# of the second person hitting "address already in use" on port 6333/11434.
#
# Two things have to be unique per researcher:
#
#   1. COMPOSE_PROJECT_NAME -- isolates your containers, network, and named
#      volumes. Without it every checkout defaults to the project name "arid"
#      and two people fight over the same containers/volumes. Use your name.
#
#   2. QDRANT_PORT / OLLAMA_PORT -- the *host* ports your stack publishes. A host
#      port can only be held by one process, so give each researcher a distinct
#      pair (e.g. bump both by the same offset). The container-internal ports
#      never change, so nothing inside the pipeline needs adjusting.
#
# Note: each project name gets its *own* volumes, so every researcher pulls the
# Ollama models and embeds the corpus once for themselves -- isolated, but not
# shared. That's the cost of running fully independent stacks side by side.
#
# If you also run the host-side scripts (venv, not `docker compose exec`) and
# you've changed the ports below, point the clients at them in the same shell:
#   export QDRANT_URL=http://localhost:${QDRANT_PORT}
#   export OLLAMA_HOST=http://localhost:${OLLAMA_PORT}

COMPOSE_PROJECT_NAME=arid-yourname
QDRANT_PORT=6333
OLLAMA_PORT=11434
